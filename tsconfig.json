{
	"compilerOptions": 
	{
		"target": "ES2022",
		"module": "NodeNext",
		"declaration": true,
		"moduleResolution": "NodeNext",
		"strict": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		/** 
		 * Because extending native objects has bad long term consequences. During 
		 * compilation do not consider as if they are included. Using it must be explicit.
		 */
		"**/native/*" 
	]
}